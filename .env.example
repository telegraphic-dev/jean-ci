# GitHub App
GITHUB_APP_ID=000000
GITHUB_WEBHOOK_SECRET=replace-with-strong-random-secret
GITHUB_APP_PRIVATE_KEY_B64=base64-encoded-pem

# GitHub OAuth (admin UI)
GITHUB_CLIENT_ID=replace-with-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-oauth-client-secret
ADMIN_GITHUB_ID=12345678

# Public app URL used for GitHub check links and webhook fallback routing
BASE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=replace-with-gateway-token

# Optional notifications / advanced features
OPENCLAW_NOTIFY_ON_CHANGES_REQUESTED=false
OPENCLAW_USE_RESPONSES=false

# Optional Coolify integration
COOLIFY_URL=https://coolify.example.com
COOLIFY_DASHBOARD_URL=https://coolify.example.com
COOLIFY_TOKEN=replace-with-coolify-token
DEFAULT_DEPLOYMENT_DOMAIN=apps.example.com

# Optional debugging
DEBUG_PIPELINE_REPO=your-org/your-repo

# Runtime
DATA_DIR=/data
PORT=3000
NODE_ENV=production
